# Copy this file to .env (which is gitignored) and fill in your real values.
# docker-compose.yml reads these automatically.

GROQ_API_KEY=your_groq_api_key_here

# Any random string — signs the Flask session cookie.
FLASK_SECRET_KEY=change_me_to_something_random

# true = full RAG (needs more RAM, pulls in chromadb/sentence-transformers/torch)
# false = RAG disabled, lighter image/runtime — see README "Deployment" section
ENABLE_RAG=true
